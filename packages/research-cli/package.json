{
  "name": "@subscription-research/cli",
  "version": "0.3.0",
  "private": false,
  "description": "Local-first subscription research workspace CLI.",
  "type": "module",
  "bin": {
    "subscription-research": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.json && node -e \"import('node:fs').then(fs => fs.chmodSync('dist/src/cli.js', 0o755))\"",
    "test": "npm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/jsdom": "^28.0.3",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.8.0",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
